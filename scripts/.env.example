# ── Wallet (Buyer) ────────────────────────────────────────────────────────────
# Base Sepolia テストネット用ウォレットの秘密鍵
# テスト用 USDC は https://faucet.circle.com/ から取得 (Base Sepolia を選択)
EVM_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
SVM_PRIVATE_KEY=

# ── CloudFront URL ─────────────────────────────────────────────────────────────
# `npx cdk deploy` 後に出力される CloudFrontUrl の値を設定
CLOUDFRONT_URL=https://XXXXX.cloudfront.net
